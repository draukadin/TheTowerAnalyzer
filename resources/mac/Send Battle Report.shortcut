			<dict>
				<key>UUID</key>
				<string>A1B2C3D4-0003-0003-0003-000000000034</string>
				<key>WFTextActionText</key>
				<string>https://ni19yt0ldg.execute-api.eu-west-1.amazonaws.com/prod/reports</string>
			</dict>
