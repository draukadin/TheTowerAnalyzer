		<!-- Action 11: HTTP POST to API Gateway -->
		<!-- URL: <api_endpoint>?runType=<run_type>&dissonanceType=<dissonance_type>  -->
		<!-- Offsets: {0,1}=api_endpoint  {10,1}=run_type  {27,1}=dissonance_type    -->
		<dict>
			<key>WFWorkflowActionIdentifier</key>
			<string>is.workflow.actions.downloadurl</string>
			<key>WFWorkflowActionParameters</key>
			<dict>
				<key>UUID</key>
				<string>A1B2C3D4-0011-0011-0011-000000000011</string>
